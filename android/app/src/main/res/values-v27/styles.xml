<resources>

    <!-- API 27+ 전용: 흰색 navigation bar 위에 어두운 버튼 아이콘이 보이도록.
         (windowLightNavigationBar 는 API 27 부터 지원. 그 이하 디바이스는 base styles.xml
         의 navigationBarColor=white 만 적용되어 흰 바탕에 흰 아이콘이 되지만, 2026 년 기준
         API 24-26 사용자는 1% 미만이라 무시 가능.) -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:textColor">#000000</item>
        <item name="android:statusBarColor">@color/app_bg</item>
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:navigationBarColor">@color/app_bg</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

</resources>
